{
  "name": "saloon-js",
  "version": "0.1.0",
  "description": "Build beautiful API integrations and SDKs with Saloon — a TypeScript port of SaloonPHP",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:lint": "biome check .",
    "test:everything": "pnpm test:unit && pnpm test:lint && pnpm typecheck",
    "lint:fix": "biome check . --write",
    "build": "tsdown",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "saloon",
    "sdk",
    "api",
    "api-integrations",
    "http-client"
  ],
  "author": "Mario Igkiempor",
  "license": "MIT",
  "homepage": "https://github.com/MariosIgkiempor/saloon-js",
  "repository": {
    "type": "git",
    "url": "https://github.com/MariosIgkiempor/saloon-js.git"
  },
  "bugs": {
    "url": "https://github.com/MariosIgkiempor/saloon-js/issues"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
